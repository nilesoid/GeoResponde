    "mission": {
      "title": "Mission",
      "p1": "GeoResponde connects scientific intelligence and humanitarian information into a unified operational picture during disasters.",
      "p2": "Instead of creating another isolated database, GeoResponde federates trusted information from existing organizations while preserving data ownership."
