  "about": {
    "title": "GeoResponde",
    "subtitle": "Sala de Situación Geoespacial Abierta",
    "mission": {
      "title": "Misión",
      "p1": "GeoResponde conecta la inteligencia científica y la información humanitaria en una imagen operativa unificada durante desastres.",
      "p2": "En lugar de crear otra base de datos aislada, GeoResponde federa información confiable de organizaciones existentes preservando la propiedad de los datos."
    },
    "whyExists": {
      "title": "Por qué existe GeoResponde",
      "p1": "Durante los desastres la información se fragmenta.",
      "p2": "Las familias buscan en múltiples sitios web.",
      "p3": "Las organizaciones duplican esfuerzos.",
      "p4": "Los científicos y socorristas a menudo trabajan con sistemas desconectados.",
      "p5": "GeoResponde existe para conectar esos mundos."
